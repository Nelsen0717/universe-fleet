<script>
(function () {
  "use strict";

  var STORAGE_KEY = "fleetOnboarding.v1";
  var UNLOCK_CODE = "首航準備完成";

  var QUESTS = ["claude-code", "codex", "node", "fleet", "coach-checkin", "meta-dev"];

  var state = loadState();

  // ---- 極淡墨星背景（恆動極慢、不搶主體） ----
  (function starfield() {
    var canvas = document.getElementById("starfield");
    if (!canvas || !canvas.getContext) return;
    var ctx = canvas.getContext("2d");
    var stars = [];
    var reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    function makeStars() {
      var count = Math.round((canvas.width * canvas.height) / 26000);
      stars = [];
      for (var i = 0; i < count; i++) {
        stars.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 1.1 + 0.3,
          phase: Math.random() * Math.PI * 2,
          speed: 0.0006 + Math.random() * 0.0006
        });
      }
    }

    function draw(t) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = "#1a1a1a";
      stars.forEach(function (s) {
        var twinkle = 0.25 + 0.35 * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
        ctx.globalAlpha = twinkle;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fill();
      });
      ctx.globalAlpha = 1;
      if (!reduceMotion) requestAnimationFrame(draw);
    }

    resize();
    makeStars();
    window.addEventListener("resize", function () {
      resize();
      makeStars();
    });

    if (reduceMotion) {
      draw(0);
    } else {
      requestAnimationFrame(draw);
    }
  })();

  // ---- 章節切換淡入 ----
  (function chapterFadeIn() {
    var chapters = document.querySelectorAll(".chapter");
    if (!chapters.length) return;
    if (!("IntersectionObserver" in window)) {
      chapters.forEach(function (c) { c.classList.add("in-view"); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    chapters.forEach(function (c) { io.observe(c); });
  })();

  function defaultState() {
    return {
      pilotName: "",
      treasures: {
        "claude-code": false,
        "codex": false,
        "node": false,
        "fleet": false,
        "coach-checkin": false,
        "meta-dev": false
      },
      selfChecks: {},
      certUnlocked: false
    };
  }

  function loadState() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return defaultState();
      var parsed = JSON.parse(raw);
      var base = defaultState();
      return Object.assign(base, parsed, {
        treasures: Object.assign(base.treasures, parsed.treasures || {}),
        selfChecks: Object.assign({}, parsed.selfChecks || {})
      });
    } catch (e) {
      return defaultState();
    }
  }

  function saveState() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    } catch (e) {
      /* localStorage 不可用時靜默略過，不擋流程 */
    }
  }

  function render() {
    // 姓名
    var nameInput = document.getElementById("pilot-name");
    if (state.pilotName) nameInput.value = state.pilotName;

    // 徽章列與寶藏卡狀態
    QUESTS.forEach(function (q) {
      var done = !!state.treasures[q];
      var badge = document.querySelector('.badge[data-badge="' + q + '"]');
      if (badge) badge.classList.toggle("done", done);

      var card = document.querySelector('.quest[data-quest="' + q + '"]');
      if (card) {
        card.classList.toggle("complete", done);
        var statusEl = card.querySelector(".quest-status");
        if (statusEl) {
          statusEl.textContent = done ? "已收下" : "尚未收下";
          statusEl.classList.toggle("done", done);
        }
      }
    });

    // 自我檢查勾選還原
    document.querySelectorAll(".self-check").forEach(function (block) {
      var key = block.getAttribute("data-selfcheck");
      var checks = state.selfChecks[key] || [];
      var boxes = block.querySelectorAll('input[type="checkbox"]');
      boxes.forEach(function (box, idx) {
        box.checked = !!checks[idx];
      });
    });

    // 證書
    if (state.certUnlocked) {
      var cert = document.getElementById("certificate");
      cert.classList.add("show");
      document.getElementById("cert-name").textContent =
        (state.pilotName || "艦長") + " 艦長";
      document.getElementById("cert-date").textContent =
        "首航準備完成日：" + new Date().toLocaleDateString("zh-TW");
    }
  }

  function playTick() {
    try {
      var AudioCtx = window.AudioContext || window.webkitAudioContext;
      if (!AudioCtx) return;
      var ctx = new AudioCtx();
      var osc = ctx.createOscillator();
      var gain = ctx.createGain();
      osc.frequency.value = 880;
      osc.type = "sine";
      gain.gain.setValueAtTime(0.06, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.12);
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.start();
      osc.stop(ctx.currentTime + 0.13);
    } catch (e) {
      /* 音訊不可用時靜默略過，不擋流程 */
    }
  }

  function markTreasure(name) {
    var wasDone = !!state.treasures[name];
    state.treasures[name] = true;
    saveState();
    render();
    if (!wasDone) {
      var badge = document.querySelector('.badge[data-badge="' + name + '"]');
      if (badge) {
        badge.classList.remove("just-done");
        // 強制 reflow 讓動畫可以重新觸發
        void badge.offsetWidth;
        badge.classList.add("just-done");
        playTick();
      }
    }
  }

  // 姓名登記
  document.getElementById("save-name-btn").addEventListener("click", function () {
    var val = document.getElementById("pilot-name").value.trim();
    var hint = document.getElementById("name-hint");
    if (!val) {
      hint.textContent = "先留個名字，證書上要印的";
      hint.className = "gate-hint error";
      return;
    }
    state.pilotName = val;
    saveState();
    hint.textContent = "登記完成，艦長";
    hint.className = "gate-hint ok";
    render();
  });

  // 平台分頁（Claude Code 寶藏卡內）
  document.querySelectorAll(".platform-tab").forEach(function (tab) {
    tab.addEventListener("click", function () {
      var platform = tab.getAttribute("data-platform");
      var group = tab.closest(".quest-body");
      group.querySelectorAll(".platform-tab").forEach(function (t) {
        t.classList.toggle("active", t === tab);
      });
      group.querySelectorAll(".platform-panel").forEach(function (p) {
        p.classList.toggle("active", p.getAttribute("data-platform") === platform);
      });
    });
  });

  // 寶藏鍵 = 真下載（window.open 官方網域）
  document.querySelectorAll(".treasure-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var url = btn.getAttribute("data-url");
      var quest = btn.getAttribute("data-quest");
      window.open(url, "_blank", "noopener");
      markTreasure(quest);
    });
  });

  // 複製鍵 = 真複製進剪貼簿，失敗則顯示可全選的備援文字框
  document.querySelectorAll(".copy-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var text = btn.getAttribute("data-copy");
      var feedback = btn.parentElement.querySelector(".copy-feedback");

      function showFeedback() {
        if (feedback) {
          feedback.classList.add("show");
          setTimeout(function () { feedback.classList.remove("show"); }, 1800);
        }
      }

      function showFallback() {
        var block = btn.closest(".quest-body") || document;
        var idBits = text.replace(/[^a-zA-Z0-9]/g, "").slice(0, 12);
        var fb = block.querySelector('[data-fallback-for]');
        // 找同一個 copy-block 底下最接近的 fallback（用相鄰 sibling 概念，找下一個 fallback-box）
        var container = btn.closest(".copy-block");
        var next = container ? container.nextElementSibling : null;
        if (next && next.classList.contains("fallback-box")) {
          next.classList.add("show");
        }
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(showFeedback, showFallback);
      } else {
        showFallback();
      }
    });
  });

  // 艦隊入列：手動確認完成鍵
  var fleetDoneBtn = document.getElementById("fleet-done-btn");
  if (fleetDoneBtn) {
    fleetDoneBtn.addEventListener("click", function () {
      markTreasure("fleet");
    });
  }

  // 自我檢查勾選即存檔
  document.querySelectorAll(".self-check").forEach(function (block) {
    var key = block.getAttribute("data-selfcheck");
    block.querySelectorAll('input[type="checkbox"]').forEach(function (box, idx) {
      box.addEventListener("change", function () {
        var checks = state.selfChecks[key] || [];
        checks[idx] = box.checked;
        state.selfChecks[key] = checks;
        saveState();
      });
    });
  });

  // 通關碼解鎖證書
  document.getElementById("unlock-btn").addEventListener("click", function () {
    var input = document.getElementById("unlock-code").value.trim();
    var hint = document.getElementById("unlock-hint");
    var normalize = function (s) { return s.replace(/\s+/g, ""); };

    if (normalize(input) === normalize(UNLOCK_CODE)) {
      markTreasure("coach-checkin");
      state.certUnlocked = true;
      saveState();
      hint.textContent = "通關碼正確，證書解鎖了";
      hint.className = "gate-hint ok";
      render();
      var cert = document.getElementById("certificate");
      cert.scrollIntoView({ behavior: "smooth", block: "center" });
    } else {
      hint.textContent = "還不太對，跟教練確認一下有沒有打錯字（注意有沒有多打空格）";
      hint.className = "gate-hint error";
    }
  });

  render();
})();
</script>
