<!doctype html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>拓荒者號 — 艦橋</title>
<link rel="icon" href="data:," />
<link rel="stylesheet" href="css/style.css" />
</head>
<body>

<div id="demo-version-banner" style="position:fixed; top:0; left:0; right:0; z-index:9999; display:flex; align-items:center; justify-content:center; gap:16px; padding:8px 16px; background:rgba(20,14,10,0.92); border-bottom:1px solid rgba(138,74,42,0.5); color:#e8ded6; font-family:'PingFang TC','Noto Sans TC','Microsoft JhengHei',sans-serif; font-size:12.5px; line-height:1.6; text-align:center;">
  <span>這是體驗版——感受學員視角用。實際課程中、這一切發生在你自己的電腦上、由你的 AI 艦隊真實執行。</span>
  <button type="button" onclick="document.getElementById('demo-version-banner').style.display='none'" style="flex-shrink:0; background:none; border:1px solid rgba(232,222,214,0.5); color:#e8ded6; font-size:11px; line-height:1; padding:4px 8px; cursor:pointer; border-radius:2px;" aria-label="關閉提示">關閉</button>
</div>

<div id="scene-root">

  <!-- 開場劇情 -->
  <section id="scene-intro" class="scene">
    <canvas id="intro-canvas"></canvas>
    <div id="intro-title-card">
      <h1>拓荒者號</h1>
      <p>「艦員都還在、他們只是睡著了。把他們一個一個叫醒、這艘艦會記得怎麼飛。」</p>
    </div>
    <div id="intro-static-fallback">
      <div>
        <h1 style="letter-spacing:0.3em;">拓荒者號</h1>
        <p style="color:var(--ink); max-width:24em; line-height:1.8;">
          「艦員都還在、他們只是睡著了。把他們一個一個叫醒、這艘艦會記得怎麼飛。」
        </p>
      </div>
    </div>
    <button id="intro-skip-btn" type="button">跳過</button>
  </section>

  <!-- 任命書：蓋章後 Nelsen 老師講清楚這遊戲是幹嘛的 -->
  <section id="scene-orders" class="scene">
    <div class="orders-shell">
      <div class="orders-stamp">任命已蓋章</div>
      <div class="orders-teacher-row">
        <div class="orders-teacher-nameplate">Nelsen 老師</div>
      </div>
      <p id="orders-briefing-line">這一關一關玩完、你的電腦上就有一支真的 AI 艦隊。開課那天、帶著它來。</p>
      <button class="back-btn" id="orders-continue-btn" type="button">出發</button>
    </div>
  </section>

  <!-- 艦橋 HUB -->
  <section id="scene-bridge" class="scene">
    <div class="bridge-layer" id="bridge-star-layer"></div>
    <div class="bridge-layer" id="bridge-mid-layer"></div>

    <div id="bridge-hud">
      <div class="hud-group">
        <span><span class="hud-label">階級</span><span id="hud-rank">見習</span></span>
        <span><span class="hud-label">連續登艦</span><span id="hud-streak">0</span></span>
        <span><span class="hud-label">航程</span><span id="hud-xp">0</span> 光年</span>
      </div>
    </div>
    <div id="bridge-title">艦橋 — 拓荒者號</div>
    <div id="bridge-subtitle">這裡的每個任務、都對應你內容事業的一件真事。</div>

    <div id="crew-row"></div>

    <div id="bridge-nav">
      <button class="nav-btn" id="nav-tasks-btn" type="button">任務板</button>
      <button class="nav-btn nav-btn-locked" id="nav-briefing-btn" type="button">晨會 <span class="nav-lock-tag">開課後解鎖</span></button>
      <button class="nav-btn nav-btn-locked" id="nav-archive-btn" type="button">檔案室 <span class="nav-lock-tag">開課後解鎖</span></button>
      <!-- 「觀測窗」「艦長室」入口暫時隱藏（2026-07-06）：功能尚未開放、避免玩家點進去只看到佔位頁。
           場景檔案（scene-placeholder）與 Placeholder.show 邏輯保留在 codebase，未來要重新啟用
           只需把下面兩顆按鈕的 HTML 加回來即可，data-placeholder-nav 機制不需要改。
      <button class="nav-btn" data-placeholder-nav="觀測窗" data-placeholder-note="訊號還在路上——成就牆與航程統計即將開放">觀測窗</button>
      <button class="nav-btn" data-placeholder-nav="艦長室" data-placeholder-note="訊號還在路上——設定與聲線檔即將開放">艦長室</button>
      -->
    </div>
  </section>

  <!-- 對話場景 -->
  <section id="scene-dialogue" class="scene">
    <div id="dialogue-portrait-wrap">
      <img id="dialogue-portrait" src="" alt="" />
    </div>
    <div id="dialogue-box">
      <div id="dialogue-speaker-name">——</div>
      <div id="dialogue-text"></div>
      <div id="dialogue-choices"></div>
    </div>
  </section>

  <!-- 任務板：M0 裝備發放（真安裝主線） -->
  <section id="scene-tasks" class="scene">
    <div class="panel-inner">
      <div class="panel-title">M0 · 裝備發放</div>
      <div id="install-quest-notice">五個寶藏、五名艦員。每收下一個寶藏、對應的艦員就會甦醒——這不是勾格子，是真的裝好。</div>
      <ol id="install-quest-list"></ol>

      <div class="panel-title compact-panel-title">開課後解鎖</div>
      <div id="task-demo-notice">這些是課程中的內容——現在先把艦隊裝起來。</div>
      <ul id="task-list" class="locked-list"></ul>
      <div id="quest-demo-notice"></div>
      <ol id="quest-list" class="locked-list"></ol>
      <ul id="placeholder-boards-list" class="locked-list"></ul>
      <button class="back-btn" id="task-back-btn" type="button">回艦橋</button>
    </div>
  </section>

  <!-- 晨會 -->
  <section id="scene-briefing" class="scene">
    <div class="panel-inner">
      <div class="mode-badge" id="briefing-mode-badge">示範資料</div>
      <div class="panel-title" id="briefing-title">晨會</div>
      <div class="briefing-host">
        <img id="briefing-host-portrait" src="assets/crew-scout.png" alt="情報員" />
        <div>
          <div id="briefing-host-name">情報員</div>
          <p id="briefing-summary"></p>
        </div>
      </div>
      <div id="briefing-signals"></div>
      <div id="briefing-daily-task"></div>
      <button class="back-btn" id="briefing-back-btn" type="button">回艦橋</button>
    </div>
  </section>

  <!-- 檔案室 -->
  <section id="scene-archive" class="scene">
    <div id="archive-bg"></div>
    <div class="archive-shell">
      <div class="mode-badge" id="archive-mode-badge">示範資料</div>
      <div class="panel-title" id="archive-title">前任艦長日誌</div>
      <div id="archive-unlock-note"></div>
      <article id="archive-book">
        <div id="archive-page-number"></div>
        <h2 id="archive-page-title"></h2>
        <p id="archive-page-body"></p>
      </article>
      <div id="archive-controls">
        <button class="back-btn" id="archive-prev-btn" type="button">上一頁</button>
        <button class="back-btn" id="archive-next-btn" type="button">下一頁</button>
      </div>
      <button class="back-btn" id="archive-back-btn" type="button">回艦橋</button>
    </div>
  </section>

  <!-- 首航慶祝 -->
  <section id="scene-celebration" class="scene">
    <canvas id="celebration-canvas"></canvas>
    <div class="celebration-inner">
      <div class="mode-badge">示範資料</div>
      <div class="panel-title">首航完成</div>
      <div id="celebration-crew"></div>
      <p id="celebration-message">五名艦員在艦橋集合。這次不是彩排，是第一篇真的出航。</p>
      <button class="back-btn" id="celebration-back-btn" type="button">回艦橋</button>
    </div>
  </section>

  <!-- 佔位頁（範圍外功能誠實標示） -->
  <section id="scene-placeholder" class="scene">
    <div class="placeholder-inner">
      <div id="placeholder-title">——</div>
      <div id="placeholder-note">——</div>
      <button class="back-btn" id="placeholder-back-btn" type="button">回艦橋</button>
    </div>
  </section>

</div>

<div id="transition-card">
  <div id="transition-card-text"></div>
</div>

<script src="js/save.js"></script>
<script src="js/sfx.js"></script>
<script src="js/scene-manager.js"></script>
<script src="js/dialogue-engine.js"></script>
<script src="js/main.js"></script>
</body>
</html>
